{
  "name": "opencode-flow",
  "version": "0.1.0",
  "description": "An npm-distributed opencode plugin that runs named sequential workflows from opencode configuration.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint -c .oxlintrc.json",
    "lint:fix": "oxlint -c .oxlintrc.json --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "prepack": "pnpm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "workflow",
    "agent"
  ],
  "author": "Marco Muellner",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarcoMuellner/opencode-flow.git"
  },
  "bugs": {
    "url": "https://github.com/MarcoMuellner/opencode-flow/issues"
  },
  "homepage": "https://github.com/MarcoMuellner/opencode-flow#readme",
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@opencode-ai/plugin": "1.17.7"
  },
  "devDependencies": {
    "@types/node": "22.15.19",
    "oxlint": "1.70.0",
    "prettier": "3.8.4",
    "typescript": "5.8.3",
    "vitest": "3.2.3"
  }
}
